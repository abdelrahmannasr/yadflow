flowchart LR
    a["author writes<br/>artifact"] --> o["open<br/>raise review PR/MR"]
    o --> c["comment<br/>reviewers leave notes"]
    c -->|owner addresses,<br/>edits in place| c
    c --> ap["approve<br/>+ resolve threads"]
    ap --> adv{"rule met,<br/>threads resolved,<br/>merged?"}
    adv -->|no — names who's missing| o
    adv -->|yes| nxt(["next step"])

    o -.companion.-> pr["🤝 pair review<br/>(yad-pair-review)"]
    pr --> stops["risk-ordered<br/>stops, one by one"]
    stops --> qa["AI briefs + asks;<br/>human answers + asks"]
    qa -->|until both satisfied| qa
    qa --> so["dual sign-off<br/>+ scorecard"]
    so -.engagement: verified.-> ap
    so -.local-only.-> learn["learning record<br/>(yad-learn → yad status)"]

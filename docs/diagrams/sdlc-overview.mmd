flowchart LR
    classDef gated fill:#fdebd0,stroke:#ca6f1e,color:#000
    classDef earns fill:#d6eaf8,stroke:#2471a3,color:#000
    classDef locked fill:#eaecee,stroke:#566573,color:#000,stroke-dasharray:5 3
    classDef artifact fill:#fcf3cf,stroke:#b7950b,color:#000
    classDef sentinel fill:#d5f5e3,stroke:#1e8449,color:#000

    subgraph SETUP["0 · One-time setup (per project)"]
      direction TB
      inst["install.sh<br/>copy yad-* skills into IDE dirs"]
      wire["wire each repo:<br/>yad-checks · yad-pr-template"]
      conn["yad-connect-repos<br/>repos.json + cached code-map"]
      sync["yad-sync-repos<br/>switch every repo to default branch + ff pull"]
      cdes["yad-connect-design<br/>design.json · Figma-first, pluggable"]
      ctest["yad-connect-testing<br/>testing.json · Playwright-first, pluggable"]
      clearn["yad-connect-learning<br/>learning.json · DeepTutor-first, pluggable"]
      phub["optional: hub on a platform<br/>detect-hub · roster"]
      inst --> wire --> conn --> sync --> cdes --> ctest --> clearn --> phub
    end

    subgraph FRONT["A · Front half — product hub · human-gated"]
      direction TB
      disc["yad-discovery<br/>optional front-zero · once per project<br/>market · competitor · feasibility · requirements · roadmap.md"]:::artifact
      gDisc{{"gate · discovery · base"}}:::gated
      dd(["currentStep: discovery-done"]):::sentinel
      disc --> gDisc --> dd
      an["yad-analysis<br/>optional → analysis.md · once per epic"]:::artifact
      ep["yad-epic<br/>epic.md · assigns EP-&lt;slug&gt;"]:::artifact
      ar["yad-architecture<br/>architecture.md + locked contract.md"]:::artifact
      ui["yad-ui<br/>optional · ui-design.md + DESIGN.md + design tool screens<br/>skippable N/A for UI-less epics"]:::artifact
      st["yad-stories<br/>repo-tagged stories/EP-&lt;slug&gt;-S0N.md"]:::artifact
      tc["yad-test-cases<br/>test-cases.md + automation tests<br/>(parallel · non-blocking)"]:::artifact
      gAn{{"gate · analysis"}}:::gated
      gEp{{"gate · epic<br/>base: owner + reviewer"}}:::gated
      gAr{{"gate · architecture<br/>escalated: + repo domain owners"}}:::gated
      gUi{{"gate · UI · base"}}:::gated
      gSt{{"gate · stories<br/>per-repo domain owners"}}:::gated
      gTc{{"gate · test cases · base"}}:::gated
      rfb(["currentStep: ready-for-build"]):::sentinel
      an --> gAn --> ep --> gEp --> ar --> gAr --> ui --> gUi --> st --> gSt --> rfb
      gSt -. opens in parallel .-> tc --> gTc
    end

    subgraph BUILD["B · Build half — per story, per code repo"]
      direction TB
      sp["yad-spec<br/>Spec Kit ceremony → specs/&lt;story&gt;/"]
      im["yad-implement<br/>1 task = 1 branch = 1 commit"]:::earns
      shp["yad-ship<br/>yad-commit + yad-open-pr"]
      ck["yad-checks<br/>spec-link · contract-check · build/test/lint<br/>verified-commits · commit-message · pr-title · pr-template<br/>lineage-check · epic-open · reconcile-debt<br/>yad-update-guard (push-on-default)"]:::earns
      prm["yad-pr-template route<br/>required reviewers"]
      air["yad-engineer-review<br/>AI review (advisory)"]
      eng{{"engineer review<br/>human · never automated"}}:::locked
      merged(["merge → build-log.json"]):::sentinel
      sp --> im --> shp --> ck --> prm --> air --> eng --> merged
    end

    subgraph AUTO["C · Automation — earned & reversible"]
      direction TB
      run["yad-run<br/>reads automation dial + trust-log.json"]:::earns
      cpt["yad checkpoint --push<br/>commit trust-log · build-log · build-state<br/>chore(hub) · default branch · allowlist-scoped"]:::artifact
      tdy["yad tidy up --push<br/>fold a shipped story's trust-log · build-log shards<br/>into the folded ledger (loose objects → git gc)"]:::artifact
      kill["kill switch → everything human_approve"]
      run --> cpt --> tdy
      run --- kill
    end

    subgraph THREAD["D · Post-lock change management — feature threads"]
      direction TB
      stub["yad-stub<br/>brownfield: feature with no epic<br/>mint stub genesis (kind:feature · stub:backfill-pending)<br/>yad-backfill promote → verified feature epic"]:::artifact
      chg["yad-change<br/>intake + triage depth<br/>seed threaded change-epic (kind/parent/thread)<br/>inherit by reference · re-author only what changes"]:::artifact
      cepic(["change-epic EP-&lt;slug&gt;<br/>pointer-lock · change.json · reconcile-debt.json"]):::sentinel
      tl["yad-timeline<br/>evolution view + thread-resolved.md (current truth)"]
      df["yad-defects<br/>quality-gap report by escape_stage"]
      rec["yad-reconcile<br/>drift / orphan / debt sweep (advisory)"]
      stub -. thread a defect off the anchor .-> chg
      chg --> cepic
      cepic -. timeline + resolved truth .-> tl
      cepic -. defect escape analysis .-> df
      cepic -. drift / open debt .-> rec
    end

    phub --> disc
    phub --> an
    dd -. roadmap frames each epic .-> ep
    rfb --> sp
    merged -. story pipeline repeats · next story .-> sp
    merged -. build-log committed by .-> cpt
    merged -. next epic · front pipeline repeats .-> ep
    merged -. sealed epic · post-lock change .-> chg
    cepic -. re-author only the changed artifacts .-> ar
    cepic -. defect / behavioural change .-> st
    run -. drives earned back steps .-> im
    bridge["yad-hub-bridge<br/>review PR/MR ↔ ledger (merge-time)"]:::gated
    bridge -. advances on merge .-> gEp
    status["yad-status<br/>read-only view over all of it"]
    status -. observes .-> FRONT
    status -. observes .-> BUILD
    learn["yad-learn<br/>learning layer · tutor any member, any stage<br/>opt-in · never gates"]:::earns
    learn -. tutors in context of .-> FRONT
    learn -. tutors in context of .-> BUILD
    learn -. local skills log .-> status

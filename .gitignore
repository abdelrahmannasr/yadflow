# OS
.DS_Store

# BMAD install (regenerable via `npx bmad-method install`)
_bmad/
_bmad-output/

# IDE skill mirrors (regenerable via `bash skills/sdlc/install.sh`)
# .claude/ is already covered by the global gitignore.
.agents/
.opencode/
.zencoder/

# Throwaway demo code repos (Phase 3). Each demo-repos/<repo>/ is its OWN git repo
# modeling a real separate code repo — never tracked by (or a submodule of) the product repo.
# The explainer demo-repos/README.md IS tracked (negation below).
demo-repos/*/
!demo-repos/README.md

# Connected-repo code-context cache (sdlc-connect-repos). The registry (.sdlc/repos.json) and the
# lightweight code-map.md per repo ARE tracked — they're small, reviewable, and the brain reads them.
# The full Repomix pack.md is a large, regenerable artifact (recreate via `action: refresh`) — ignored.
.sdlc/code-context/*/pack.md

# Empty/generated scaffolding
design-artifacts/
skills/reports/

# Node
node_modules/
